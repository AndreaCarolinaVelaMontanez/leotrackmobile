generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                    @id @default(uuid())
  name                     String
  email                    String                    @unique
  password                 String?
  emailVerified            Boolean                   @default(false) @map("email_verified")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  googleId                 String?                   @unique @map("google_id")
  country                  String?
  authSessions             AuthSession[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  userBooks                UserBook[]
  settings                 UserSettings?

  @@map("users")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model AuthSession {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model Book {
  id           String     @id @default(uuid())
  title        String
  author       String
  category     String?
  coverUrl     String?    @map("cover_url")
  pageCount    Int?       @map("page_count")
  language     String?
  googleBookId String?    @unique @map("google_book_id")
  source       BookSource @default(MANUAL)
  createdAt    DateTime   @default(now()) @map("created_at")
  userBooks    UserBook[]

  @@map("books")
}

model UserBook {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  bookId          String           @map("book_id")
  status          ReadingStatus    @default(WISHLIST)
  currentPage     Int              @default(0) @map("current_page")
  totalMinutes    Int              @default(0) @map("total_minutes")
  startedAt       DateTime?        @map("started_at")
  finishedAt      DateTime?        @map("finished_at")
  recommended     Boolean?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  progressLogs    ProgressLog[]
  readingSessions ReadingSession[]
  bookTags        BookTag[]
  book            Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, status])
  @@map("user_books")
}

model BookTag {
  id         String   @id @default(uuid())
  userBookId String   @map("user_book_id")
  tag        String
  createdAt  DateTime @default(now()) @map("created_at")
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@map("book_tags")
}

model ProgressLog {
  id         String   @id @default(uuid())
  userBookId String   @map("user_book_id")
  pagesRead  Int      @map("pages_read")
  createdAt  DateTime @default(now()) @map("created_at")
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId, createdAt])
  @@map("progress_logs")
}

model ReadingSession {
  id              String   @id @default(uuid())
  userBookId      String   @map("user_book_id")
  startedAt       DateTime @map("started_at")
  endedAt         DateTime @map("ended_at")
  durationMinutes Int      @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  userBook        UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)

  @@index([userBookId, startedAt])
  @@map("reading_sessions")
}

model UserSettings {
  id       String   @id @default(uuid())
  userId   String   @unique @map("user_id")
  language Language @default(EN)
  theme    Theme    @default(LIGHT)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

enum BookSource {
  GOOGLE
  MANUAL
}

enum ReadingStatus {
  READING
  FINISHED
  WISHLIST
  ABANDONED
}

enum Language {
  EN
  ES
}

enum Theme {
  LIGHT
  DARK
}
