{
  "name": "leotrack-backend",
  "version": "1.0.0",
  "description": "LeoTrack - Book Tracking API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "npx prisma migrate deploy && node dist/index.js",
